    def generate_case(self, difficulty=DifficultyLevel.LEVEL_1, case_type=None, 
                     infection_source=None, include_answer_key=True, 
                     include_teaching_points=True):
        """
        Generate a mock sepsis case with full EHR data and answer key.
        
        Args:
            difficulty: Level 1 (straightforward), Level 2 (intermediate), Level 3 (advanced)
            case_type: Specific case type or random if None
            infection_source: Specific source or random if None
            include_answer_key: Include correct answers and CDI actions
            include_teaching_points: Include teaching points for instructors
        
        Returns:
            Dictionary with complete case data, answer key, and teaching points
        """
        
        # Select case type
        if case_type is None:
            case_type = random.choice(list(CaseType))
        elif isinstance(case_type, str):
            case_type = CaseType[case_type.upper()]
        
        # Select infection source
        if infection_source is None:
            infection_source = random.choice(list(self.infection_sources.keys()))
        
        # Generate case based on type and difficulty
        if case_type == CaseType.MISSED_SEVERITY:
            case_data = self._build_missed_severity_case(difficulty, infection_source)
        elif case_type == CaseType.DENIAL_TRAP:
            case_data = self._build_denial_trap_case(difficulty, infection_source)
        elif case_type == CaseType.SEPSIS_ONLY:
            case_data = self._build_sepsis_only_case(difficulty, infection_source)
        elif case_type == CaseType.S2_ONLY:
            case_data = self._build_s2_only_case(difficulty, infection_source)
        elif case_type == CaseType.S3_ONLY:
            case_data = self._build_s3_only_case(difficulty, infection_source)
        elif case_type == CaseType.UNDOCUMENTED:
            case_data = self._build_undocumented_case(difficulty, infection_source)
        elif case_type == CaseType.MISDOCUMENTED:
            case_data = self._build_misdocumented_case(difficulty, infection_source)
        elif case_type == CaseType.SHOCK_MISCLASSIFICATION:
            case_data = self._build_shock_misclassification_case(difficulty, infection_source)
        elif case_type == CaseType.RESOLVED_SEPSIS:
            case_data = self._build_resolved_sepsis_case(difficulty, infection_source)
        else:
            case_data = self._build_missed_severity_case(difficulty, infection_source)
        
        # Add answer key if requested
        if include_answer_key:
            case_data["answer_key"] = self._generate_answer_key(case_data)
        
        # Add teaching points if requested
        if include_teaching_points:
            case_data["teaching_points"] = self._generate_teaching_points(case_data)
        
        # Store in database for grading reference
        case_id = case_data["case_id"]
        self.case_database[case_id] = case_data
        
        return case_data
    
