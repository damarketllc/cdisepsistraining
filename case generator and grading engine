    def _determine_documentation_status(self, case_data):
        """Determine if documentation is correct, unsupported, undocumented, or misdocumented."""
        
        case_type = case_data.get("case_type")
        clinical_data = case_data.get("clinical_data", {})
        
        if case_type == CaseType.MISSED_SEVERITY.value:
            return "Documented as 'Sepsis' but should be 'Severe Sepsis' (organ dysfunction present)"
        elif case_type == CaseType.DENIAL_TRAP.value:
            return "Documented as 'Septic Shock' (S2 valid) but fails S3 criteria (lactate &lt;2)"
        elif case_type == CaseType.UNDOCUMENTED.value:
            return "Sepsis/Severe Sepsis clinically supported but not documented"
        elif case_type == CaseType.MISDOCUMENTED.value:
            return "Documented as 'Sepsis' but criteria not met (SIRS without infection)"
        elif case_type == CaseType.SHOCK_MISCLASSIFICATION.value:
            return "Documented as 'Septic Shock' but shock criteria not met"
        elif case_type == CaseType.RESOLVED_SEPSIS.value:
            return "Sepsis documented but criteria no longer met (resolution not documented)"
        else:
            return "Correctly documented"
    
    def _determine_cdi_action(self, case_data):
        """Determine required CDI action."""
        
        case_type = case_data.get("case_type")
        
        if case_type == CaseType.MISSED_SEVERITY.value:
            return "ISSUE PROVIDER QUERY: Document 'Severe Sepsis' (organ dysfunction present: lactate >2.0). Accurately reflects severity of illness and risk of mortality."
        elif case_type == CaseType.DENIAL_TRAP.value:
            return "FLAG FOR COMPREHENSIVE REVIEW: Diagnosis valid under Sepsis 2 but fails Sepsis 3 criteria (lactate &lt;2.0). Ensure medical record heavily documents clinical signs of cardiovascular failure to defend against payor downgrades."
        elif case_type == CaseType.UNDOCUMENTED.value:
            return "ADD SEPSIS/SEVERE SEPSIS DIAGNOSIS: Criteria clearly met; documentation required for accurate coding and quality reporting."
        elif case_type == CaseType.MISDOCUMENTED.value:
            return "REMOVE OR CLARIFY SEPSIS DIAGNOSIS: Criteria not met. Document as 'Post-operative fever, rule out infection' or 'SIRS, etiology unclear'."
        elif case_type == CaseType.SHOCK_MISCLASSIFICATION.value:
            return "CLARIFY SHOCK DIAGNOSIS: Ensure fluid resuscitation, hypotension, and vasopressor requirement are explicitly documented to support shock classification."
        elif case_type == CaseType.RESOLVED_SEPSIS.value:
            return "UPDATE DOCUMENTATION: Sepsis resolved. Document as 'Sepsis, resolved' or remove diagnosis if no longer clinically relevant."
        else:
            return "Documentation appropriate; no action required."
    
    def _determine_regulatory_notes(self, case_data):
        """Determine regulatory implications (CMS vs. Payor)."""
        
        clinical_data = case_data.get("clinical_data", {})
        s2_class = clinical_data.get("sepsis_2_classification", "")
        s3_class = clinical_data.get("sepsis_3_classification", "")
        
        notes = {
            "cms_sepsis_2_valid": "Yes" if "Sepsis" in s2_class or "Severe Sepsis" in s2_class or "Septic Shock" in s2_class else "No",
            "payor_sepsis_3_valid": "Yes" if "Sepsis" in s3_class or "Septic Shock" in s3_class else "No",
            "conflict": "Yes" if ("Yes" in notes.get("cms_sepsis_2_valid", "No") and "No" in notes.get("payor_sepsis_3_valid", "Yes")) or ("No" in notes.get("cms_sepsis_2_valid", "Yes") and "Yes" in notes.get("payor_sepsis_3_valid", "No")) else "No"
        }
        
        return notes
    
