class SepsisGradingEngine:
    """Automated grading system for trainee responses."""
    
    def __init__(self, case_database):
        self.case_database = case_database
        self.rubric = {
            "sepsis_2_assessment": 25,
            "sepsis_3_assessment": 25,
            "documentation_status": 25,
            "recommendations": 15,
            "clinical_reasoning": 10
        }
    
    def grade_response(self, case_id, trainee_response):
        """
        Grade trainee response against answer key.
        
        Args:
            case_id: Case ID from generated case
            trainee_response: Dictionary with trainee's answers
        
        Returns:
            Grading report with score, feedback, and recommendations
        """
        
        if case_id not in self.case_database:
            return {"error": "Case not found in database"}
        
        case_data = self.case_database[case_id]
        answer_key = case_data.get("answer_key", {})
        
        score = 0
        feedback = {}
        
        # Section 1: Sepsis 2 Assessment (25 points)
        s2_score, s2_feedback = self._grade_sepsis_2(trainee_response, answer_key)
        score += s2_score
        feedback["sepsis_2"] = s2_feedback
        
        # Section 2: Sepsis 3 Assessment (25 points)
        s3_score, s3_feedback = self._grade_sepsis_3(trainee_response, answer_key)
        score += s3_score
        feedback["sepsis_3"] = s3_feedback
        
        # Section 3: Documentation Status (25 points)
        doc_score, doc_feedback = self._grade_documentation_status(trainee_response, answer_key)
        score += doc_score
        feedback["documentation"] = doc_feedback
        
        # Section 4: Recommendations (15 points)
        rec_score, rec_feedback = self._grade_recommendations(trainee_response, answer_key)
        score += rec_score
        feedback["recommendations"] = rec_feedback
        
        # Section 5: Clinical Reasoning (10 points)
        reason_score, reason_feedback = self._grade_clinical_reasoning(trainee_response)
        score += reason_score
        feedback["reasoning"] = reason_feedback
        
        # Calculate grade
        percentage = (score / 100) * 100
        grade = self._calculate_grade(percentage)
        
        # Generate recommendations
        recommendations = self._generate_recommendations(grade, feedback)
        
        grading_report = {
            "case_id": case_id,
            "total_score": score,
            "percentage": round(percentage, 1),
            "grade": grade,
            "section_feedback": feedback,
            "strengths": self._identify_strengths(feedback),
            "areas_for_improvement": self._identify_improvements(feedback),
            "next_steps": recommendations
        }
        
        return grading_report
    
    def _grade_sepsis_2(self, trainee_response, answer_key):
        """Grade Sepsis 2 assessment (25 points)."""
        score = 0
        feedback = {}
        
        trainee_s2 = trainee_response.get("sepsis_2_classification", "")
        correct_s2 = answer_key.get("sepsis_2_classification", "")
        
        if trainee_s2.lower() == correct_s2.lower():
            score += 25
            feedback["result"] = "✅ Correct"
        elif "Sepsis" in trainee_s2 and "Sepsis" in correct_s2:
            score += 15
            feedback["result"] = "⚠️ Partially correct (classification level off)"
        else:
            score += 0
            feedback["result"] = "❌ Incorrect"
        
        feedback["trainee_answer"] = trainee_s2
        feedback["correct_answer"] = correct_s2
        
        return score, feedback
    
    def _grade_sepsis_3(self, trainee_response, answer_key):
        """Grade Sepsis 3 assessment (25 points)."""
        score = 0
        feedback = {}
        
        trainee_s3 = trainee_response.get("sepsis_3_classification", "")
        correct_s3 = answer_key.get("sepsis_3_classification", "")
        
        if trainee_s3.lower() == correct_s3.lower():
            score += 25
            feedback["result"] = "✅ Correct"
        elif "Sepsis" in trainee_s3 and "Sepsis" in correct_s3:
            score += 15
            feedback["result"] = "⚠️ Partially correct"
        else:
            score += 0
            feedback["result"] = "❌ Incorrect"
        
        feedback["trainee_answer"] = trainee_s3
        feedback["correct_answer"] = correct_s3
        
        return score, feedback
    
    def _grade_documentation_status(self, trainee_response, answer_key):
        """Grade documentation status assessment (25 points)."""
        score = 0
        feedback = {}
        
        trainee_status = trainee_response.get("documentation_status", "")
        correct_status = answer_key.get("documentation_status", "")
        
        if trainee_status.lower() == correct_status.lower():
            score += 25
            feedback["result"] = "✅ Correct"
        elif any(keyword in trainee_status.lower() for keyword in ["correct", "unsupported", "undocumented", "misdocumented"]):
            score += 15
            feedback["result"] = "⚠️ Partially correct (details off)"
        else:
            score += 0
            feedback["result"] = "❌ Incorrect"
        
        feedback["trainee_answer"] = trainee_status
        feedback["correct_answer"] = correct_status
        
        return score, feedback
    
    def _grade_recommendations(self, trainee_response, answer_key):
        """Grade recommendations (15 points)."""
        score = 0
        feedback = {}
        
        trainee_rec = trainee_response.get("recommendations", "")
        correct_rec = answer_key.get("cdi_required_action", "")
        
        # Check if trainee identified correct action type
        if any(action in trainee_rec.lower() for action in ["query", "flag", "add", "remove", "clarify", "update"]):
            score += 10
            feedback["action_identified"] = "✅ Correct action type identified"
        else:
            score += 0
            feedback["action_identified"] = "❌ Action type not identified"
        
        # Check if rationale is provided
        if len(trainee_rec) > 50:
            score += 5
            feedback["rationale"] = "✅ Adequate rationale provided"
        else:
            score += 0
            feedback["rationale"] = "❌ Insufficient rationale"
        
        feedback["trainee_answer"] = trainee_rec
        feedback["correct_answer"] = correct_rec
        
        return score, feedback
    
    def _grade_clinical_reasoning(self, trainee_response):
        """Grade clinical reasoning and justification (10 points)."""
        score = 0
        feedback = {}
        
        reasoning = trainee_response.get("reasoning", "")
        
        # Check clarity and logic
        if len(reasoning) > 100 and any(word in reasoning.lower() for word in ["because", "therefore", "indicates", "suggests"]):
            score += 5
            feedback["clarity"] = "✅ Clear logical reasoning"
        else:
            score += 2
            feedback["clarity"] = "⚠️ Reasoning could be clearer"
        
        # Check terminology use
        if any(term in reasoning.lower() for term in ["sirs", "sofa", "lactate", "organ dysfunction", "vasopressor"]):
            score += 3
            feedback["terminology"] = "✅ Appropriate clinical terminology"
        else:
            score += 1
            feedback["terminology"] = "⚠️ Limited use of clinical terminology"
        
        # Check regulatory awareness
        if any(term in reasoning.lower() for term in ["cms", "payor", "sepsis 2", "sepsis 3", "s2", "s3"]):
            score += 2
            feedback["regulatory_awareness"] = "✅ Regulatory implications recognized"
        else:
            score += 0
            feedback["regulatory_awareness"] = "⚠️ Regulatory implications not mentioned"
        
        return score, feedback
    
    def _calculate_grade(self, percentage):
        """Convert percentage to letter grade."""
        if percentage >= 90:
            return "A"
        elif percentage >= 80:
            return "B"
        elif percentage >= 70:
            return "C"
        elif percentage >= 60:
            return "D"
        else:
            return "F"
    
    def _identify_strengths(self, feedback):
        """Identify areas where trainee performed well."""
        strengths = []
        for section, data in feedback.items():
            if "✅" in str(data.get("result", "")):
                strengths.append(f"{section.replace('_', ' ').title()}: {data.get('result', '')}")
        return strengths if strengths else ["Review feedback for specific strengths"]
    
    def _identify_improvements(self, feedback):
        """Identify areas for improvement."""
        improvements = []
        for section, data in feedback.items():
            if "❌" in str(data.get("result", "")):
                improvements.append(f"{section.replace('_', ' ').title()}: {data.get('result', '')}")
        return improvements if improvements else ["Overall performance is strong"]
    
    def _generate_recommendations(self, grade, feedback):
        """Generate next steps based on performance."""
        if grade == "A":
            return "Advance to Level 3 cases or instructor-led lab"
        elif grade == "B":
            return "Review specific sections; practice additional Level 2 cases"
        elif grade == "C":
            return "Focused review of weak areas; repeat Level 2 cases"
        elif grade == "D":
            return "Remedial training on core concepts; return to Level 1"
        else:
            return "Comprehensive review required; one-on-one instruction recommended"

